# Managed by Ansible — 1Password Connect binds on all interfaces; inbound to this port on
# **net0** is blocked by Proxmox CT guest firewall (see **create-iac-controller-lxc.sh**).
# Matches upstream https://github.com/1Password/connect/tree/main/examples/docker/compose
# (shared op/data volume is required; do not override user: let image opuser own state).
services:
  op-connect-api:
    image: 1password/connect-api:latest
    pull_policy: always
    restart: unless-stopped
    ports:
      - "{{ iac_connect_api_port }}:8080"
    volumes:
      - type: bind
        source: {{ iac_connect_credentials_path }}
        target: /home/opuser/.op/1password-credentials.json
        read_only: true
      - op_connect_data:/home/opuser/.op/data

  op-connect-sync:
    image: 1password/connect-sync:latest
    pull_policy: always
    restart: unless-stopped
    environment:
      OP_CONNECT_HOST: "http://op-connect-api:8080"
    volumes:
      - type: bind
        source: {{ iac_connect_credentials_path }}
        target: /home/opuser/.op/1password-credentials.json
        read_only: true
      - op_connect_data:/home/opuser/.op/data
    depends_on:
      - op-connect-api

volumes:
  op_connect_data:
